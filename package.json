{
  "name": "@esmaeel_emadi/nestjs-metadata",
  "version": "0.1.0",
  "description": "Metadata-driven UI generation for NestJS — database-backed forms, tables, screens, and navigation modules with tenant overrides.",
  "license": "MIT",
  "author": "emadi68moh@gmail.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/EsmaeelEmadi/nestjs-metadata"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas/index.js",
      "require": "./dist/schemas/index.js",
      "types": "./dist/schemas/index.d.ts"
    },
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "format": "npx @biomejs/biome format --write .",
    "lint": "npx @biomejs/biome lint --write .",
    "check": "npx @biomejs/biome check --write .",
    "hooks:install": "npx lefthook install",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@esmaeel_emadi/nestjs-core": ">=0.1",
    "@esmaeel_emadi/ts-exc": ">=0.1",
    "@nestjs-cls/transactional": ">=3",
    "@nestjs/common": ">=10",
    "@nestjs/event-emitter": ">=3",
    "@nestjs/swagger": ">=7",
    "drizzle-orm": ">=0.30",
    "nestjs-cls": ">=6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@esmaeel_emadi/nestjs-core": "file:../nestjs-core/esmaeel_emadi-nestjs-core-0.1.0.tgz",
    "@esmaeel_emadi/ts-exc": "link:../ts-exc",
    "@nestjs-cls/transactional": "^3.2.1",
    "@nestjs-cls/transactional-adapter-drizzle-orm": "^1.3.0",
    "@nestjs/common": "^11.1.26",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/swagger": "^11.4.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "@types/node": "^25.9.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-orm-pg": "^0.16.3",
    "lefthook": "^1.11.13",
    "nestjs-cls": "^6.2.1",
    "reflect-metadata": "^0.2.2",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "nestjs",
    "metadata",
    "forms",
    "tables",
    "screens",
    "drizzle",
    "ui-generation",
    "multi-tenant"
  ],
  "pnpm": {
    "overrides": {
      "@nestjs/common": "11.1.24",
      "nestjs-cls": "6.2.1",
      "@nestjs-cls/transactional": "3.2.1"
    }
  }
}
